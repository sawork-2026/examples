<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- 同样的 MovieLister，换一个 MovieFinder 实现 -->

    <bean id="MovieFinder" class="moviefinder.InMemoryMovieFinder">
        <constructor-arg>
            <list>
                <bean class="moviefinder.Movie">
                    <constructor-arg index="0" value="Inception"/>
                    <constructor-arg index="1" value="Christopher Nolan"/>
                </bean>
                <bean class="moviefinder.Movie">
                    <constructor-arg index="0" value="The Dark Knight"/>
                    <constructor-arg index="1" value="Christopher Nolan"/>
                </bean>
                <bean class="moviefinder.Movie">
                    <constructor-arg index="0" value="Interstellar"/>
                    <constructor-arg index="1" value="Christopher Nolan"/>
                </bean>
            </list>
        </constructor-arg>
    </bean>

    <bean id="MovieLister" class="moviefinder.MovieLister">
        <constructor-arg ref="MovieFinder"/>
    </bean>

</beans>
